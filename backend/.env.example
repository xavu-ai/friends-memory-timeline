# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/friends_memory

# Authentication - JSON format
FRIEND_PASSWORDS={"alice": "secret1", "bob": "secret2"}
# OR comma-separated format: "alice:secret1,bob:secret2"

# CORS - explicit origins only
CORS_ORIGINS=["http://localhost:8100"]

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
