# Database
DATABASE_URL=sqlite+aiosqlite:///./friends_memory.db

# JWT Authentication
JWT_SECRET=your-secret-key-min-32-chars-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS - explicit origins only
ALLOWED_ORIGINS=["http://localhost:8100"]

# Passwords - JSON array of allowed passwords
PASSWORDS=["password1", "password2", "password3"]
